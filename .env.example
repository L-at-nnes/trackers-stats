# Intervalle de scraping (en minutes)
SCRAPE_INTERVAL_MINUTES=60

# Heure de début des scrapes (alignement). Laisser vide pour démarrer immédiatement.
# Exemple : 00:00 = scrapes à 00h, 06h, 12h, 18h (si interval=360)
SCRAPE_START_TIME=

# Port du serveur web
PORT=3000

# ── C411 ──────────────────────────────────────────────
C411_USERNAME=
C411_PASSWORD=

# ── La Cale ───────────────────────────────────────────
LACALE_USERNAME=
LACALE_PASSWORD=

# ── Torr9 ─────────────────────────────────────────────
TORR9_USERNAME=
TORR9_PASSWORD=
# ── ABN ──────────────────────────────────────────
ABN_USERNAME=
ABN_PASSWORD=

# ── TheOldSchool (UNIT3D) ─────────────────────
TOS_USERNAME=
TOS_PASSWORD=

# ── Generation-Free (UNIT3D) ──────────────────
GF_USERNAME=
GF_PASSWORD=

